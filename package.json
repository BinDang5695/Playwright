{
  "name": "playwright",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "test:all": "playwright test",
    "test:all:chrome": "set env=crm-dev&& playwright test --project=chrome",
    "test:all:edge": "set env=crm-dev&& playwright test --project=edge",
    "test:api": "playwright test tests/api/ --project=api",
    "test:api:book": "playwright test tests/api/ApiBookTest.spec.ts --project=api",
    "test:api:image": "playwright test tests/api/ApiImageTest.spec.ts --project=api",
    "test:api:user": "playwright test tests/api/ApiUserTest.spec.ts --project=api",
    "test:ui:dev:chrome": "set env=crm-dev&& playwright test tests/ui/ --project=chrome",
    "test:ui:dev:edge": "set env=crm-dev&& playwright test tests/ui/ --project=edge",
    "test:crm:contract:chrome:admin": "set env=crm-dev&& playwright test tests/ui/ContractTest.spec.ts --project=chrome",
    "test:crm:contract:edge:admin": "set env=crm-dev&& playwright test tests/ui/ContractTest.spec.ts --project=edge",
    "test:crm:customerdatadriven:chrome": "set env=crm-dev&& playwright test tests/ui/CustomerDataDrivenTest.spec.ts --project=chrome",
    "test:crm:customerdatadriven:edge": "set env=crm-dev&& playwright test tests/ui/CustomerDataDrivenTest.spec.ts --project=edge",
    "test:crm:customer:chrome": "set env=crm-dev&& playwright test tests/ui/CustomerTest.spec.ts --project=chrome",
    "test:crm:customer:edge": "set env=crm-dev&& playwright test tests/ui/CustomerTest.spec.ts --project=edge",
    "test:crm:expenses:chrome": "set env=crm-dev&& playwright test tests/ui/ExpensesTest.spec.ts --project=chrome",
    "test:crm:expenses:edge": "set env=crm-dev&& playwright test tests/ui/ExpensesTest.spec.ts --project=edge",
    "test:crm:item:chrome": "set env=crm-dev&& playwright test tests/ui/ItemTest.spec.ts --project=chrome",
    "test:crm:item:edge": "set env=crm-dev&& playwright test tests/ui/ItemTest.spec.ts --project=edge",
    "test:crm:knowledgebase:chrome": "set env=crm-dev&& playwright test tests/ui/KnowledgeBaseTest.spec.ts --project=chrome",
    "test:crm:knowledgebase:edge": "set env=crm-dev&& playwright test tests/ui/KnowledgeBaseTest.spec.ts --project=edge",
    "test:crm:lead:chrome": "set env=crm-dev&& playwright test tests/ui/LeadTest.spec.ts --project=chrome",
    "test:crm:lead:edge": "set env=crm-dev&& playwright test tests/ui/LeadTest.spec.ts --project=edge",
    "test:crm:login:chrome": "set env=crm-dev&& playwright test tests/ui/LoginTest.spec.ts --project=chrome",
    "test:crm:login:edge": "set env=crm-dev&& playwright test tests/ui/LoginTest.spec.ts --project=edge",
    "test:crm:project:chrome": "set env=crm-dev&& playwright test tests/ui/ProjectTest.spec.ts --project=chrome",
    "test:crm:project:edge": "set env=crm-dev&& playwright test tests/ui/ProjectTest.spec.ts --project=edge",
    "test:crm:proposal:chrome": "set env=crm-dev&& playwright test tests/ui/ProposalTest.spec.ts --project=chrome",
    "test:crm:proposal:edge": "set env=crm-dev&& playwright test tests/ui/ProposalTest.spec.ts --project=edge",
    "test:crm:task:chrome": "set env=crm-dev&& playwright test tests/ui/TaskTest.spec.ts --project=chrome",
    "test:crm:task:edge": "set env=crm-dev&& playwright test tests/ui/TaskTest.spec.ts --project=edge",
    "create:playwright:report": "npx playwright show-report",
    "create:allure-report": "allure generate allure-results -o allure-report --clean && allure open allure-report"
  },
  "dependencies": {
    "@playwright/test": "^1.57.0",
    "ajv": "^8.17.1",
    "ajv-draft-04": "^1.0.0",
    "ajv-formats": "^3.0.1",
    "canvas": "^3.2.0",
    "dotenv": "^17.3.1",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^3.11.174",
    "properties-reader": "^2.3.0",
    "typescript": "^5.9.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@types/node": "^25.0.3",
    "@types/pdf-parse": "^1.1.5",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.2",
    "eslint": "^10.2.0",
    "rimraf": "^6.1.3"
  }
}
