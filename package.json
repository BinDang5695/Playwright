{
  "name": "playwright",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test tests/api/ --project=api",
    "test:fb": "playwright test tests/ui/football/RegistrationTest.spec.ts --project=fb",
    "test:cms": "set env=cms-dev&& playwright test tests/ui/cms/ --project=cms",
    "test:crm": "set env=crm-dev&& playwright test tests/ui/crm/ --project=crm",
    "test:all": "npm run test:api && npm run test:cms && npm run test:fb && npm run test:crm"
  },
  "dependencies": {
    "@playwright/test": "^1.57.0",
    "ajv": "^8.17.1",
    "ajv-draft-04": "^1.0.0",
    "ajv-formats": "^3.0.1",
    "canvas": "^3.2.0",
    "dotenv": "^17.3.1",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^3.11.174",
    "properties-reader": "^2.3.0",
    "typescript": "^5.9.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@types/node": "^25.0.3",
    "@types/pdf-parse": "^1.1.5",
    "allure-playwright": "^3.4.3"
  }
}