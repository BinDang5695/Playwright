{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2021", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["pages/*"],
      "@fixtures/*": ["fixtures/*"],
      "@api/*": ["api/*"],
      "@data/*": ["test_data/*"],
      "@models/*": ["models/*"],
      "@utils/*": ["utils/*"],
      "@constants/*": ["constants/*"],
      "@helpers/*": ["models/helpers/*"],
      "@env/*": ["env/*"]
    }
  },

  "include": [
    "tests/**/*.ts",
    "pages/**/*.ts",
    "api/**/*.ts",
    "models/**/*.ts",
    "fixtures/**/*.ts",
    "test_data/**/*.ts",
    "utils/**/*.ts",
    "constants/**/*.ts",
    "env/**/*.ts",
  ]
}